# =============================================================
# ZALLDI PLATFORM — Environment Variables
# =============================================================
# Copy this file to .env.local in each app directory
# and fill in real values from your Supabase project.
# =============================================================

# ------------------------------------------------------------
# SUPABASE (required by all apps)
# Get these from: https://supabase.com/dashboard → your project → Settings → API
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------------------------------------------------------------
# APP URLS (for CORS, redirects, OAuth callbacks)
# ------------------------------------------------------------
NEXT_PUBLIC_CUSTOMER_WEB_URL=https://zalldi.com
NEXT_PUBLIC_ADMIN_URL=https://admin.zalldi.com
NEXT_PUBLIC_SELLER_URL=https://seller.zalldi.com
NEXT_PUBLIC_DSTORE_URL=https://dstore.zalldi.com

# For local development:
# NEXT_PUBLIC_CUSTOMER_WEB_URL=http://localhost:3000
# NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
# NEXT_PUBLIC_SELLER_URL=http://localhost:3002
# NEXT_PUBLIC_DSTORE_URL=http://localhost:3003

# ------------------------------------------------------------
# APP IDENTITY (set per-app in each app's .env.local)
# ------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=Zalldi
NEXT_PUBLIC_APP_ENV=development
